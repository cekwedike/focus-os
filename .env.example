# Focus OS environment variables
# Copy this file to .env and fill in values. Never commit .env to version control.

# OpenRouter (optional, primary Daily Insight provider)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=

# Ollama (optional, offline fallback)
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=

# Optional: override SQLite path for development (uncomment when implemented)
# FOCUS_OS_DB_PATH=./data/focus-os.dev.db
